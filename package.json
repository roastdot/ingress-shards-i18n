{
    "name": "@ingress-shards/ingress-shards-map",
    "version": "0.0.0-semantically-released",
    "description": "Interactive map of shard data from Ingress events",
    "author": {
        "name": "Nick Young"
    },
    "contributors": [
        "Lewis Keen"
    ],
    "license": "MIT",
    "homepage": "https://roastdot.github.io/ingress-shards.github.io/",
    "repository": {
        "type": "git",
        "url": "https://github.com/roastdot/ingress-shards.github.io.git"
    },
    "bugs": {
        "url": "https://github.com/roastdot/ingress-shards.github.io/issues"
    },
    "type": "module",
    "private": true,
    "main": "dist/main.bundle.js",
    "scripts": {
        "clean": "node -e \"const fs = require('fs'); ['gen', 'dist'].forEach(p => fs.rmSync(p, { recursive: true, force: true }))\"",
        "start": "npm run prepare:data && webpack serve --config webpack.dev.js",
        "build": "npm run prepare:data && webpack --config webpack.prod.js",
        "geocode": "python scripts/geocode.py",
        "data:process": "tsx scripts/pre-processor-loader.ts",
        "data:validate": "tsx scripts/validator-loader.ts",
        "data:statistics": "tsx scripts/statistics-loader.ts",
        "mkdir:gen": "node -e \"if (!require('fs').existsSync('gen')) require('fs').mkdirSync('gen', { recursive: true })\"",
        "prepare:data": "npm run mkdir:gen && npm run geocode && npm run data:process && npm run data:validate && npm run data:statistics",
        "validate": "npm run clean && npm run build",
        "typecheck": "tsc --noEmit",
        "test:3d": "tsx --test tests/map-3d.test.ts",
        "preview": "tsx scripts/preview-ci-artifact.ts"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@eslint/json": "^0.14.0",
        "@semantic-release/exec": "^7.1.0",
        "@types/leaflet": "^1.9.21",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "conventional-changelog-conventionalcommits": "^9.1.0",
        "css-loader": "^7.1.2",
        "esbuild-loader": "^4.5.0",
        "eslint": "^9.39.1",
        "globals": "^16.5.0",
        "html-webpack-plugin": "^5.6.4",
        "semantic-release": "^25.0.2",
        "semantic-release-export-data": "^1.2.0",
        "style-loader": "^4.0.0",
        "tsx": "^4.23.1",
        "typescript": "^7.0.2",
        "webpack": "^5.101.3",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.2",
        "webpack-merge": "^6.0.1"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^9.2.0",
        "@mui/material": "^9.2.0",
        "cesium": "^1.143.0",
        "copy-webpack-plugin": "^14.0.0",
        "flag-icon-css": "^4.1.7",
        "leaflet": "^1.9.4",
        "leaflet-providers": "^2.0.0",
        "leaflet-relief": "^1.4.0",
        "leaflet.motion": "github:neon-ninja/leaflet.motion",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "temporal-polyfill": "^0.3.2"
    }
}
